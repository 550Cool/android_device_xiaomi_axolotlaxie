/tz             emmc     /dev/block/bootdevice/by-name/tz             flags=display=tz
/rpm            emmc     /dev/block/bootdevice/by-name/rpm            flags=display=rpm
/hyp            emmc     /dev/block/bootdevice/by-name/hyp            flags=display=hyp
/cmnlib         emmc     /dev/block/bootdevice/by-name/cmnlib         flags=display=cmnlib
/keymaster      emmc     /dev/block/bootdevice/by-name/keymaster      flags=display=keymaster
/abl            emmc     /dev/block/bootdevice/by-name/abl            flags=display=abl
/modem          emmc     /dev/block/bootdevice/by-name/modem          flags=display=modem
/dsp            emmc     /dev/block/bootdevice/by-name/dsp            flags=display=dsp
/sdl            emmc     /dev/block/bootdevice/by-name/sdl            flags=display=sdl
/version        emmc     /dev/block/bootdevice/by-name/version        flags=display=version
/mdtp           emmc     /dev/block/bootdevice/by-name/mdtp           flags=display=mdtp
